# Copy this to worker/.env and fill in the values.
# NEVER commit worker/.env to git.

SUPABASE_URL=https://painvmazwbzbzdejfioa.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<paste your service role key here>

# "mathew" for the text model machine, "qwen" for the vision model machine
WORKER_TYPE=mathew

# LM Studio URL — localhost since the worker runs on the same machine
LM_STUDIO_URL=http://127.0.0.1:1234/v1

# Model name as shown in LM Studio
LM_MODEL=qwen/qwen3-4b-2507

# API key configured in LM Studio (Settings → Developer → API Keys)
LM_API_KEY=lm-studio
